{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "VERCEL_TELEMETRY_DISABLED": "1",
    "TURBO_TELEMETRY_DISABLED": "1",
    "RAILWAY_NO_TELEMETRY": "1",
    "DO_NOT_TRACK": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(bun:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(for:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git clean:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git mv:*)",
      "Bash(git push:*)",
      "Bash(git rm:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git worktree:*)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh search:*)",
      "Bash(gh status:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(playwright-cli:*)",
      "Bash(pnpm:*)",
      "Bash(ripgrep:*)",
      "Bash(sed:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(tr:*)",
      "Bash(vite:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Read(~/.claude/**)",
      "Read(./**)",
      "Skill(*)",
      "ToolSearch",
      "WebFetch",
      "WebSearch",
      "Write(//tmp/**)",
      "mcp__mcp-registry__search_mcp_registry",
      "mcp__plugin_context7_context7__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.local.env)",
      "Read(./secrets/**)",
      "Read(~/.zshrc)",
      "Write(./.git/**)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/auto-approve-safe-commands.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs your approval\" with title \"Claude Code Permission\" sound name \"Glass\"' & afplay /System/Library/Sounds/Glass.aiff &"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude is done\" with title \"Claude Code\" sound name \"Blow\"' & afplay /System/Library/Sounds/Blow.aiff &"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh -c '[ -f .claude/hooks/statusline-command.sh ] && sh .claude/hooks/statusline-command.sh || sh ~/.claude/hooks/statusline-command.sh'"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "outputStyle": "Explanatory",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "gihub.com",
        "*.github.com",
        "*.githubusercontent.com",
        "*.npmjs.org",
        "*.yarnpkg.com",
        "*.pypi.org",
        "*.anthropic.com",
        "*.amazonaws.com",
        "*.googleapis.com",
        "*.context7.com",
        "*.smithery.ai"
      ],
      "allowUnixSockets": [],
      "allowAllUnixSockets": false,
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "/tmp/",
        "/private/tmp/",
        "./"
      ],
      "denyRead": [
        "~/.npmrc",
        "~/.config",
        "~/.zshrc",
        "~/.zshenv"
      ],
      "allowRead": [
        "~/.config/gh/",
        "~/.claude/",
        "./"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": []
  },
  "effortLevel": "medium",
  "companyAnnouncements": [
    "🚀🛸🪐👽 woohoo ",
    "🤡 What ya gonna build?",
    "🤔 Billion dollar idea brewing...",
    "You deserve a break ☕️ or 🚽",
    "🌌🧠 Cosmic download complete 🚀",
    "🛠️🤖 Builder mode: activated",
    "⚡🧠 Neural fireworks exploding, genius alert! 🤓",
    "🚀🪐 Orbit achieved, now colonize the impossible! 👽🛸",
    "🔥🍪 Fresh batch of billion-dollar heat rising! 🔥",
    "🦸‍♂️ Cape optional, world-saving mandatory today! 🛡️",
    "🎲🌀 Chaos dice rolled: jackpot reality incoming! 💰",
    "🌈💡 Prism of pure potential cracking open... dive in! 🏊‍♂️",
    "☕️ Midnight rocket fuel activated: dream big or go home! 🏠"
  ],
  "voiceEnabled": true,
  "autoDreamEnabled": false
}
