{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.local.env)",
      "Read(./secrets/**)",
      "Read(~/.zshrc)",
      "Write(./.git/**)"
    ],
    "allow": [
      "Bash(bun:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(for:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git clean:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git worktree:*)",
      "Bash(gh api:*)",
      "Bash(gh pr:*)",
      "Bash(gh search:*)",
      "Bash(gh status:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(ripgrep:*)",
      "Bash(sed:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(tr:*)",
      "Bash(vite:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Read(~/.claude/**)",
      "Read(./**)",
      "ToolSearch",
      "WebFetch",
      "WebSearch",
      "Write(//tmp/**)",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_serena_serena__activate_project",
      "mcp__plugin_serena_serena__check_onboarding_performed",
      "mcp__plugin_serena_serena__find_file",
      "mcp__plugin_serena_serena__get_symbols_overview",
      "mcp__plugin_serena_serena__list_dir",
      "mcp__plugin_serena_serena__onboarding",
      "mcp__plugin_serena_serena__read_file",
      "mcp__plugin_serena_serena__search_for_pattern",
      "mcp__plugin_serena_serena__write_memory"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [],
    "filesystem": {
      "denyRead": [],
      "allowRead": [
        "~/.claude/",
        "./"
      ],
      "allowWrite": [
        "/tmp/",
        "/private/tmp/",
        "./"
      ]
    },
    "network": {
      "allowUnixSockets": [],
      "allowAllUnixSockets": false,
      "allowLocalBinding": true,
      "allowedDomains": [
        "*.github.com",
        "*.githubusercontent.com",
        "*.npmjs.org",
        "*.yarnpkg.com",
        "*.pypi.org",
        "*.anthropic.com",
        "*.amazonaws.com",
        "*.googleapis.com"
      ]
    },
    "enableWeakerNestedSandbox": false
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/auto-approve-safe-commands.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs your approval\" with title \"Claude Code Permission\" sound name \"Glass\"' & afplay /System/Library/Sounds/Glass.aiff &"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh -c '[ -f .claude/hooks/statusline-command.sh ] && sh .claude/hooks/statusline-command.sh || sh ~/.claude/hooks/statusline-command.sh'"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "stripe@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true
  },
  "companyAnnouncements": [
    "🚀🛸🪐👽 woohoo ",
    "🤡 What ya gonna build?",
    "🤔 Billion dollar idea brewing...",
    "You deserve a break ☕️ or 🚽",
    "🌌🧠 Cosmic download complete 🚀",
    "🛠️🤖 Builder mode: activated",
    "⚡🧠 Neural fireworks exploding, genius alert! 🤓",
    "🚀🪐 Orbit achieved, now colonize the impossible! 👽🛸",
    "🔥🍪 Fresh batch of billion-dollar heat rising! 🔥",
    "🦸‍♂️ Cape optional, world-saving mandatory today! 🛡️",
    "🎲🌀 Chaos dice rolled: jackpot reality incoming! 💰",
    "🌈💡 Prism of pure potential cracking open... dive in! 🏊‍♂️",
    "☕️ Midnight rocket fuel activated: dream big or go home! 🏠"
  ],
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
